{
  "name": "hackathon-new-again",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-all.mjs",
    "build": "npm run typecheck && vite build",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run --passWithNoTests",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "server:dev": "node --env-file=.env --experimental-strip-types --watch server/index.ts",
    "server:start": "node --env-file=.env --experimental-strip-types server/index.ts",
    "dev:web": "vite"
  },
  "dependencies": {
    "discord.js": "^14.25.1",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.4.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^5.4.21",
    "vitest": "^4.0.18"
  }
}
